MONGODB_URI=mongodb://localhost:27017/bible-comment
NEXTAUTH_SECRET=your-secret-key-here-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Optional: leave empty to disable error reporting (Sentry init becomes a no-op)
SENTRY_DSN=

# Email (Resend). Leave RESEND_API_KEY empty in dev — sendEmail becomes a no-op
# that logs the payload. EMAIL_TRANSPORT=memory captures sends in process memory
# for Cypress / a11y runs (see /api/_test/last-email).
RESEND_API_KEY=
EMAIL_FROM="Bible Comment <onboarding@resend.dev>"
EMAIL_TRANSPORT=
APP_URL=http://localhost:3000
