MONGODB_URI=mongodb://localhost:27017/bible-comment
NEXTAUTH_SECRET=your-secret-key-here-change-in-production
NEXTAUTH_URL=http://localhost:3000

# Sentry — leave both empty in dev, init becomes a no-op.
# Server: SENTRY_DSN is read by src/instrumentation.ts (Node + Edge runtimes).
# Client: NEXT_PUBLIC_SENTRY_DSN is read by sentry.client.config.ts (browser).
# Use the same DSN for both — Sentry's project ingest endpoint accepts events
# from any runtime tagged with that DSN.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Sentry build-time vars — only needed in CI/Netlify so source maps upload.
# Generate SENTRY_AUTH_TOKEN at https://sentry.io/settings/account/api/auth-tokens/
# with scopes: project:releases, project:write.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Email (Resend). Leave RESEND_API_KEY empty in dev — sendEmail becomes a no-op
# that logs the payload. EMAIL_TRANSPORT=memory captures sends in process memory
# for Cypress / a11y runs (see /api/dev/last-email).
RESEND_API_KEY=
EMAIL_FROM="Bible Comment <onboarding@resend.dev>"
EMAIL_TRANSPORT=
APP_URL=http://localhost:3000
